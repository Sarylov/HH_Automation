# Application
NODE_ENV=development
PORT=3000
TZ=Europe/Moscow

# PostgreSQL
POSTGRES_USER=hh
POSTGRES_PASSWORD=hh_secret
POSTGRES_DB=hh_automation
POSTGRES_PORT=5432
DATABASE_URL=postgresql://hh:hh_secret@localhost:5432/hh_automation?schema=public

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# n8n
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
BACKEND_API_URL=http://host.docker.internal:3000/api

# Playwright
HH_BASE_URL=https://hh.ru
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_DEBUG_PAUSE_MS=0
PLAYWRIGHT_PORT=3100
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3100
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=30000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=60000
PLAYWRIGHT_STORAGE_STATE_PATH=./.auth/storage-state.json
PLAYWRIGHT_ARTIFACTS_DIR=./artifacts

# Vacancy search defaults
HH_SEARCH_TEXT=frontend developer
HH_SEARCH_AREA=1
HH_SEARCH_PAGES=1
HH_EXCLUDED_TEXT=backend, fullstack, full-stack
HH_WORK_FORMAT=REMOTE
HH_SEARCH_PERIOD=3
HH_SEARCH_FIELD=name

# HH credentials (optional — prefer manual storageState)
HH_LOGIN=
HH_PASSWORD=

# LLM (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# Applicant context for LLM (optional free-text profile)
APPLICANT_PROFILE=

# Apply pacing
APPLY_DELAY_MIN_MS=3000
APPLY_DELAY_MAX_MS=15000

# Full pipeline without clicking Apply on hh.ru
DRY_RUN=false

# Resume maintenance (Phase 4)
# Comma-separated HH resume IDs (optimizer uses first two)
HH_RESUME_IDS=
RESUME_RAISE_COOLDOWN_HOURS=1
RESUME_OPTIMIZE_COOLDOWN_DAYS=3

# Messaging (Phase 5)
CHAT_PROCESSOR_LIMIT=10
FOLLOW_UP_DELAY_DAYS=3
FOLLOW_UP_MAX_REMINDERS=3

# Hardening (Phase 6)
WORKING_HOURS_ENABLED=true
WORKING_HOURS_START=09:00
WORKING_HOURS_END=19:00
WORKING_DAYS=1-5
APPLY_MAX_PER_HOUR=10
APPLY_MAX_PER_DAY=40
HH_ACTION_MIN_INTERVAL_MS=8000
SESSION_MAX_AGE_HOURS=72
QUEUE_STUCK_THRESHOLD=25
APPLY_FAIL_ALERT_THRESHOLD=5

# Internal service auth (placeholders)
INTERNAL_API_KEY=change_me
