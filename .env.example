# Application
NODE_ENV=development
PORT=3000
# Local tip: if Cursor/another app holds 127.0.0.1:3000, set PORT=3001 and
# match apps/web vite proxy target (see apps/web/vite.config.ts).
TZ=Europe/Moscow

# GHCR images (compose on server / CI)
# GHCR_OWNER=your-github-username-or-org
# IMAGE_TAG=latest

# PostgreSQL
POSTGRES_USER=hh
POSTGRES_PASSWORD=hh_secret
POSTGRES_DB=hh_automation
POSTGRES_PORT=5432
# Host apps: localhost. Inside compose, backend overrides to @postgres.
DATABASE_URL=postgresql://hh:hh_secret@localhost:5432/hh_automation?schema=public

# n8n (local without Traefik)
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678/
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_PROXY_HOPS=1
# Compose default talks to backend service; override only for host-run backend
BACKEND_API_URL=http://backend:3000/api

# n8n + Traefik (server) — used with docker-compose.traefik.yml
# Set domain and HTTPS URLs; keep N8N_PORT=5678 (container listen port).
# N8N_DOMAIN=n8n.example.com
# N8N_HOST=n8n.example.com
# N8N_PROTOCOL=https
# N8N_EDITOR_BASE_URL=https://n8n.example.com/
# N8N_WEBHOOK_URL=https://n8n.example.com/
# TRAEFIK_NETWORK=proxy
# TRAEFIK_ENTRYPOINT=websecure
# TRAEFIK_CERT_RESOLVER=letsencrypt

# Ops UI (apps/web)
WEB_PORT=8080
# Traefik (server): DNS A/CNAME for WEB_DOMAIN → server IP
# WEB_DOMAIN=ops.example.com

# Playwright
HH_BASE_URL=https://hh.ru
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_DEBUG_PAUSE_MS=0
PLAYWRIGHT_PORT=3100
# Host-run backend → 127.0.0.1. Compose backend overrides to http://playwright:3100
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3100
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=30000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=60000
# Host paths; compose mounts apps/playwright/.auth → /data/.auth
PLAYWRIGHT_STORAGE_STATE_PATH=./.auth/storage-state.json
PLAYWRIGHT_ARTIFACTS_DIR=./artifacts

# Upload session to server: npm run deploy:session (from apps/playwright)
# DEPLOY_SSH_HOST = SSH config Host alias (e.g. jalsan) or user@host
# DEPLOY_SSH_REMOTE_PATH = absolute path to storage-state.json on the server
DEPLOY_SSH_HOST=jalsan
DEPLOY_SSH_REMOTE_PATH=/opt/hh-automation/apps/playwright/.auth/storage-state.json

# Vacancy search defaults
HH_SEARCH_TEXT=frontend developer
# Optional. Prefer passing "area" in POST /api/workflows/vacancy-scanner body.
# If omitted in the request, search has no region filter (no default Moscow).
# HH_SEARCH_AREA=1
HH_SEARCH_PAGES=1
HH_EXCLUDED_TEXT=backend, fullstack, full-stack
HH_WORK_FORMAT=REMOTE
HH_SEARCH_PERIOD=3
HH_SEARCH_FIELD=name

# HH credentials (optional — prefer manual storageState)
HH_LOGIN=
HH_PASSWORD=

# LLM (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# Applicant context for LLM (optional free-text profile)
APPLICANT_PROFILE=

# Vacancy LLM analysis before cover letter (set false to skip; code kept)
LLM_VACANCY_ANALYSIS_ENABLED=true

# Apply pacing
APPLY_DELAY_MIN_MS=3000
APPLY_DELAY_MAX_MS=15000

# Full pipeline without clicking Apply on hh.ru
DRY_RUN=false

# Resume maintenance (Phase 4)
# Comma-separated HH resume IDs (optimizer uses first two)
HH_RESUME_IDS=
RESUME_RAISE_COOLDOWN_HOURS=1
RESUME_OPTIMIZE_COOLDOWN_DAYS=3

# Messaging (Phase 5)
CHAT_PROCESSOR_LIMIT=10
FOLLOW_UP_DELAY_DAYS=3
FOLLOW_UP_MAX_REMINDERS=3

# Hardening (Phase 6)
WORKING_HOURS_ENABLED=true
WORKING_HOURS_START=09:00
WORKING_HOURS_END=19:00
WORKING_DAYS=1-5
APPLY_MAX_PER_HOUR=10
APPLY_MAX_PER_DAY=40
APPLY_JOB_STUCK_MINUTES=30
HH_ACTION_MIN_INTERVAL_MS=8000
SESSION_MAX_AGE_HOURS=72
QUEUE_STUCK_THRESHOLD=25
APPLY_FAIL_ALERT_THRESHOLD=5

# Internal service auth (placeholders)
INTERNAL_API_KEY=change_me
